# ── image tags(已 pin 確切版本;升級時同步更新四個 tag 並重新驗證) ──
VL_IMAGE_TAG=victoriametrics/victoria-logs:v1.51.0
VM_IMAGE_TAG=victoriametrics/victoria-metrics:v1.147.0
VMALERT_IMAGE_TAG=victoriametrics/vmalert:v1.147.0
ALERTMANAGER_IMAGE_TAG=prom/alertmanager:v0.33.1

# ── VL Basic Auth(若 VL 開了 -httpAuth;沒開就留空) ──
DUCKLOG_VL_USERNAME=
DUCKLOG_VL_PASSWORD=

# ── 通知出口 ──
DUCKLOG_ALERT_WEBHOOK_URL=http://sink:8080/hook
DUCKLOG_TELEGRAM_BOT_TOKEN=dummy:token
DUCKLOG_TELEGRAM_CHAT_ID=1
